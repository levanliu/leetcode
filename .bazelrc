# ============================================================================
# MaterialLink Bazel Configuration
# Supports: Linux (gcc/clang) + Windows (MSVC)
# ============================================================================

# ============================================================================
# 1. Platform Detection
# ============================================================================
# Automatically applies build:linux or build:windows based on host OS
common --enable_platform_specific_config

# ============================================================================
# 2. Common Settings (cross-platform)
# ============================================================================
common --ui_event_filters=-warning
common --noshow_loading_progress
common --incompatible_strict_action_env
common --incompatible_disallow_empty_glob

# ============================================================================
# 3. Cache Configuration
# ============================================================================
# User-specific cache paths (generated by tools/bazel wrapper)
import %workspace%/tools/user_config.bazelrc

# Disk cache garbage collection
common --experimental_disk_cache_gc_max_size=150G
common --experimental_disk_cache_gc_max_age=8d

# Remote cache (server configured in /etc/bazel.bazelrc.site)
common --remote_upload_local_results
common --remote_download_all
build --remote_cache_compression
build --remote_local_fallback

# ============================================================================
# 4. Build Settings
# ============================================================================
build --verbose_failures
build --nobuild_runfile_links
build --experimental_guard_against_concurrent_changes
# build:linux --explain='/tmp/bazel-explain'

# ============================================================================
# 5. C++ Configuration (Linux — GCC/Clang)
# ============================================================================
build:linux --action_env=BAZEL_CXXOPTS="-std=c++17:-Wextra:-Wno-error=unused-parameter"
build:linux --cxxopt=-std=c++17
build:linux --host_cxxopt=-std=c++17
build:linux --features=-treat_warnings_as_errors
build:linux --host_features=-treat_warnings_as_errors
build:linux --copt=-Werror
build:linux --copt=-Wno-error=deprecated-declarations
build:linux --copt=-Wno-error=unused-parameter
build:linux --per_file_copt=external/.*@-Wno-error
build:linux --per_file_copt=external/.*@-Wno-deprecated-declarations
build:linux --host_copt=-Wno-error
build:linux --host_per_file_copt=.*@-Wno-error

run:linux --action_env=BAZEL_CXXOPTS="-std=c++17:-Wextra:-Wno-error=unused-parameter"

# --- Windows (MSVC) ---
# Note: Use build.ps1 scripts, which automatically handle
#       Windows path length limitations via --output_user_root parameter
# Note: Symlinks require Windows Developer Mode enabled
#   Settings > Update & Security > For developers > Developer Mode
# Uncomment below to enable symlinks (may improve build performance):
# build:windows --windows_enable_symlinks
build:windows --cxxopt=/std:c++17
build:windows --host_cxxopt=/std:c++17
build:windows --cxxopt=/permissive-
build:windows --host_cxxopt=/permissive-
build:windows --cxxopt=/utf-8
build:windows --host_cxxopt=/utf-8
build:windows --define=protobuf_allow_msvc=true
build:windows --action_env=BAZEL_CXXOPTS="-std=c++17"
build:windows --enable_runfiles=no

run:windows --action_env=BAZEL_CXXOPTS="-std=c++17"

# ============================================================================
# 6. C++ Toolchains
# ============================================================================
# gcc — use default_toolchain (no target_settings) to avoid circular dependency
build:gcc-toolset-13 --extra_toolchains="//bzl_tools/bazel/toolchains/gcc-toolset-13:default_toolchain"

build:gcc-toolset-14 --extra_toolchains="//bzl_tools/bazel/toolchains/gcc-toolset-14:default_toolchain"

build:gcc-toolset-latest --config=gcc-toolset-14

# clang
build:clang-21 --extra_toolchains="//bzl_tools/bazel/toolchains/llvm-clang-21:default_toolchain"
build:clang-21 --extra_execution_platforms="//:linux_clang_x86"

build:clang-22 --extra_toolchains="//bzl_tools/bazel/toolchains/llvm-clang-22:default_toolchain"
build:clang-22 --extra_execution_platforms="//:linux_clang_x86"

build:clang-latest --config=clang-22

# default toolchain — gcc-toolset-13 for Linux builds
build:linux --config=gcc-toolset-13

# ============================================================================
# 7. Test Configuration
# ============================================================================
test --test_summary=detailed
test --test_verbose_timeout_warnings
test --nozip_undeclared_test_outputs
test:linux --sandbox_tmpfs_path=/tmp
