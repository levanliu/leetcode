{
    // ── C/C++ Extension ──────────────────────────────────────────
    // Disable Microsoft IntelliSense in favor of clangd
    "C_Cpp.intelliSenseEngine": "disabled",

    // ── Clangd ───────────────────────────────────────────────────
    "clangd.path": "/opt/hp93000rt/el9/x86_64/llvm-clang-20/bin/clangd",
    "clangd.arguments": [
        "-log=verbose",
        "-pretty",
        "--background-index",
        "--compile-commands-dir=${workspaceFolder}",
        "--header-insertion=never",
        "--clang-tidy"
    ],

    // ── lldb ───────────────────────────────────────────────────
    "lldb-dap.executable-path": "/opt/hp93000rt/el9/x86_64/llvm-clang-20/bin/lldb",

    // ── C++ Editor ───────────────────────────────────────────────
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    // ── Bazel ────────────────────────────────────────────────────
    "bazel.executable": "bazelisk",

    // ── PlantUML ─────────────────────────────────────────────────
    "plantuml.exportFormat": "svg",
    "plantuml.exportOutDir": "workspace/docs/svgs",
    "plantuml.diagramsRoot": "workspace/docs/markdowns",
    "plantuml.exportSubFolder": false,
    "plantuml.server": "https://www.plantuml.com/plantuml",
    "plantuml.render": "PlantUMLServer",

    // ── Copilot / Chat ───────────────────────────────────────────
    "chat.promptFilesRecommendations": {
        "speckit.constitution": true,
        "speckit.specify": true,
        "speckit.plan": true,
        "speckit.tasks": true,
        "speckit.implement": true
    },
    "chat.tools.terminal.autoApprove": {
        ".specify/scripts/bash/": true,
        ".specify/scripts/powershell/": true
    },

    // ── Editor ───────────────────────────────────────────────────
    "editor.inlineSuggest.enabled": true,
    "editor.quickSuggestions": {
        "other": "inline",
        "comments": true,
        "strings": true
    },
    "editor.quickSuggestionsDelay": 100
}
