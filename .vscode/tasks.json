{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build test (debug)",
      "type": "shell",
      "command": "bazelisk",
      "args": [
        "build",
        "-c",
        "dbg",
        "//${relativeFileDirname}:${fileBasenameNoExtension}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*\\.cpp):(\\d+):(\\d+): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}