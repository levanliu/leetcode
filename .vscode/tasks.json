{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Write execroot sourcemap",
      "type": "shell",
      "command": "echo \"settings set target.source-map $(readlink -f bazel-bin/../../..) ${workspaceFolder}\" > .vscode/lldb_sourcemap.txt",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": { "reveal": "never" }
    },
    {
      "label": "Build test (debug)",
      "type": "shell",
      "command": "bazelisk build -c dbg //${relativeFileDirname}:${fileBasenameNoExtension}",
      "dependsOn": "Write execroot sourcemap",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.*\\.cpp):(\\d+):(\\d+): (.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        }
      }
    }
  ]
}